# copy to `.env` and edit.

# PostgreSQL (dvdrental)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mysecretpassword
POSTGRES_DB=dvdrental

# MCP streamable HTTP
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_SERVER_URL=http://127.0.0.1:8000/mcp

# App memory database
APP_MEMORY_HOST=localhost
APP_MEMORY_PORT=5433
APP_MEMORY_USER=postgres
APP_MEMORY_PASSWORD=mysecretpassword
APP_MEMORY_DB=app_memory
DEFAULT_USER_ID=default
DEFAULT_THREAD_ID=default-thread

# Query pipeline
QUERY_MAX_REFINEMENTS=3

# LiteLLM
LLM_SERVICE_URL=https://sa-llmproxy.it.itba.edu.ar
LLM_API_KEY=
LLM_MODEL=gpt-5-nano
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=120.0
LLM_MAX_RETRIES=3

# Graph debug logging
GRAPH_DEBUG=true
