# copy to `.env` and edit.

# POSTGRES
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mysecretpassword
POSTGRES_DB=dvdrental

# MCP streamable HTTP
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_SERVER_URL=http://127.0.0.1:8000/mcp

# Schema gate (default: data/schema_presence.json)
# SCHEMA_PRESENCE_PATH=/absolute/or/relative/path/schema_presence.json

# Approved schema documentation JSON (default: data/schema_docs.json)
# SCHEMA_DOCS_PATH=/absolute/or/relative/path/schema_docs.json

# Raw MCP inspect_schema dump from ``python main.py`` (default: data/schema_catalog.json)
# SCHEMA_EXPORT_PATH=/absolute/or/relative/path/schema_catalog.json

# Optional: future LLM-backed drafting (not required for stub draft)
# SCHEMA_AGENT_MODEL=gpt-4o-mini
# OPENAI_API_KEY=...
